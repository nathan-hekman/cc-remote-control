# Phone number (E.164) that receives the confirmation reply.
# Use the same number you'll iMessage *from* — the router replies to this
# number, and macOS Shortcuts triggers on incoming messages to your Mac.
IMESSAGE_TARGET="+15551234567"

# Prefix on every reply iMessage. Used for loop avoidance — the router
# silently drops any incoming message that starts with this string,
# so Mac-sent replies don't re-trigger the Shortcut.
# Keep it short and free of the literal word "claude" (lowercase) since
# the trigger is "contains claude" case-insensitive.
IMESSAGE_PREFIX="[CR]"

# Model used to infer which project to open from the message body.
# Haiku is plenty for this and is cheap + fast.
ROUTER_MODEL="claude-haiku-4-5-20251001"

# Primary projects directory — scanned one level deep for candidate project
# slugs. Default is $HOME/Documents. Always wrap in double quotes so that
# $HOME expands and paths with spaces still parse.
PROJECTS_ROOT="$HOME/Documents"

# Optional: comma-separated extra dirs to scan one level deep. Handy if
# you keep some projects nested. Example:
# PROJECTS_ROOT_EXTRA="$HOME/Documents/Other Projects,$HOME/code"
PROJECTS_ROOT_EXTRA=""

# Optional: comma-separated subdir names to skip (matched on basename).
# Dotfiles are always skipped automatically. If PROJECTS_ROOT_EXTRA points
# at a subfolder of PROJECTS_ROOT, add its basename here so it isn't
# scanned twice (once as a project, once as a parent dir).
# Example: PROJECTS_EXCLUDE="logs,Zoom,node_modules,Other Projects"
PROJECTS_EXCLUDE=""
